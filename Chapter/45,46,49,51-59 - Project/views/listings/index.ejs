<% layout("/layouts/boilerplate") %>

<div class="container my-4">
    <div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-1 g-4">
        <% for(let listing of allListings) { %>
            <a href="/listings/<%= listing._id %>" class="listing-link col">
                <div class="card listing-card h-100 shadow-sm">
                    <img 
                        src="<%= listing.image.url %>" 
                        class="card-img-top card-img-custom" 
                        alt="listing_image"
                    >
                    
                    <div class="card-body p-3">
                        <h6 class="card-title fw-bold mb-1"><%= listing.title %></h6>
                        
                        <p class="card-text text-muted mb-1" style="font-size: 0.9rem;">
                            <i class="fa-solid fa-location-dot me-1"></i><%= listing.location %>
                        </p>
                        
                        <p class="card-text fw-bold">
                            &#8377;<%= listing.price.toLocaleString("en-IN") %> / night
                        </p>
                    </div>
                </div>
            </a>
            <% } %>
    </div>
</div>
